# Public project configuration used by the website build.
VITE_SITE_URL=
VITE_SANITY_PROJECT_ID=your-project-id
VITE_SANITY_DATASET=production

# Studio configuration. Use the same project and dataset values.
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Optional: required only when the dataset is private.
# Create a Viewer token and configure it only in the server/deployment environment.
SANITY_API_READ_TOKEN=

# Optional: populated by Sanity when deploying the Studio as an application.
SANITY_STUDIO_APP_ID=

# EmailJS configuration for the Contact Us form.
VITE_EMAILJS_SERVICE_ID=your-service-id
VITE_EMAILJS_TEMPLATE_ID=your-template-id
VITE_EMAILJS_PUBLIC_KEY=your-public-key
